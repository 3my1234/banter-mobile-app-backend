# Server Configuration
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
DOMAIN=sportbanter.online
FRONTEND_URL=https://your-frontend-domain.com
APP_ROLE=all

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/banter_db
DB_CONNECTION_LIMIT=20
DB_POOL_TIMEOUT_SEC=20
DB_USE_PGBOUNCER=0

# Privy Configuration
PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret

# Redis Configuration (for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=

# AWS S3 Configuration (for image uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET_NAME=banter-uploads
MEDIA_PIPELINE_SECRET=replace_with_strong_secret
MEDIA_CDN_BASE=https://media.sportbanter.online

# Flutterwave Configuration
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key
FLUTTERWAVE_REDIRECT_URL=banterv3://payments/flutterwave
FLUTTERWAVE_LOGO_URL=https://your-cdn-domain.com/logo.png
BACKEND_PUBLIC_URL=https://sportbanter.online
PRESALE_REDIRECT_URL=https://buy.sportbanter.online
FX_RATE_TTL_SECONDS=900
FLUTTERWAVE_NGN_RATE=
EXCHANGERATE_HOST_KEY=

# Movement Network Configuration
MOVEMENT_TESTNET_RPC=https://testnet.movementnetwork.xyz/v1
MOVEMENT_INDEXER_URL=https://indexer.testnet.movementnetwork.xyz/v1/graphql
MOVEMENT_USDC_ADDRESS=0xb89077cfd2a82a0c1450534d49cfd5f2707643155273069bc23a912bcfefdee7
MOVEMENT_ROL_ADDRESS=your_rol_token_address
MOVEMENT_USDC_RECEIVER=your_movement_usdc_receiver_address
ROLLEY_SERVICE_URL=https://sportbanter.online/rolley

# Banter Points Configuration
BANTER_POINTS_DAILY_LOGIN_RAW=10
BANTER_POINTS_EARLY_USER_RAW=500
BANTER_POINTS_EARLY_USER_CUTOFF_AT=
BANTER_POINTS_FIRST_ROLLEY_STAKE_RAW=75
BANTER_POINTS_PCA_VOTE_RAW=5
BANTER_ROAST_SURVIVAL_ROL_RAW=100000

# Solana Configuration
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
SOLANA_USDC_RECEIVER=your_solana_usdc_receiver_address

# JWT Secret (for internal JWT if needed)
JWT_SECRET=your_jwt_secret_key_change_in_production

# HTTP Rate Limits
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=60

# Wallet Overview Caching
WALLET_OVERVIEW_CACHE_TTL_MS=5000
WALLET_OVERVIEW_CACHE_MAX_ENTRIES=1000

# Queue Backpressure
QUEUE_WORKER_CONCURRENCY=5
QUEUE_WORKER_RATE_LIMIT_MAX=0
QUEUE_WORKER_RATE_LIMIT_DURATION_MS=0
QUEUE_JOB_ATTEMPTS=3
QUEUE_JOB_BACKOFF_MS=5000
QUEUE_JOB_REMOVE_ON_COMPLETE=1000
QUEUE_JOB_REMOVE_ON_FAIL=5000
